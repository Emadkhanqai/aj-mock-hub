{
  "name": "@aj-mock-hub/source",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "npm@11.8.0",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start:web": "nx serve web",
    "start:api": "nx serve api",
    "start:worker": "nx serve worker",
    "db:generate": "prisma generate --config prisma.config.ts",
    "db:migrate": "prisma migrate dev --config prisma.config.ts",
    "db:migrate:test": "prisma migrate deploy --config prisma.test.config.ts",
    "db:seed": "prisma db seed --config prisma.config.ts",
    "db:status": "prisma migrate status --config prisma.config.ts",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "lint": "nx run-many -t lint --all",
    "test": "npm run db:generate && nx run-many -t test --all",
    "test:integration": "npm run db:generate && npm run db:migrate:test && nx run-many -t integration-test -p api,worker --parallel=1",
    "build": "npm run db:generate && nx run-many -t build --all"
  },
  "private": true,
  "devDependencies": {
    "@angular-devkit/core": "~22.0.4",
    "@angular-devkit/schematics": "~22.0.4",
    "@angular/build": "~22.0.4",
    "@angular/cli": "~22.0.4",
    "@angular/compiler-cli": "~22.0.4",
    "@angular/language-service": "~22.0.4",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/angular": "23.1.0",
    "@nx/eslint": "23.1.0",
    "@nx/eslint-plugin": "23.1.0",
    "@nx/jest": "23.1.0",
    "@nx/js": "23.1.0",
    "@nx/nest": "23.1.0",
    "@nx/node": "23.1.0",
    "@nx/web": "23.1.0",
    "@nx/webpack": "23.1.0",
    "@nx/workspace": "23.1.0",
    "@schematics/angular": "~22.0.4",
    "@swc/helpers": "~0.5.18",
    "@types/jest": "~30.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.1",
    "@typescript-eslint/utils": "^8.58.0",
    "angular-eslint": "^22.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "~30.3.0",
    "jest-environment-node": "~30.3.0",
    "jest-util": "~30.3.0",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "23.1.0",
    "prettier": "~3.6.2",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.7",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.0.8",
    "webpack": "^5.101.3",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "^5.2.1",
    "webpack-node-externals": "3.0.0"
  },
  "dependencies": {
    "@angular/common": "~22.0.4",
    "@angular/compiler": "~22.0.4",
    "@angular/core": "~22.0.4",
    "@angular/forms": "~22.0.4",
    "@angular/platform-browser": "~22.0.4",
    "@angular/router": "~22.0.4",
    "@fontsource-variable/geist": "5.2.9",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bullmq": "5.80.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "ioredis": "5.11.1",
    "mammoth": "^1.12.0",
    "minio": "^8.0.7",
    "openai": "^6.48.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "~7.8.0",
    "zod": "^4.4.3"
  }
}
