# NON-PRODUCTION defaults for local development only.
# Copy this file to .env and never reuse these credentials outside a local machine.
POSTGRES_DB=aj_mock_hub
POSTGRES_USER=aj_mock_hub
POSTGRES_PASSWORD=local_only_change_me
POSTGRES_PORT=5432
DATABASE_URL=postgresql://aj_mock_hub:local_only_change_me@127.0.0.1:5432/aj_mock_hub?schema=public
TEST_DATABASE_URL=postgresql://aj_mock_hub:local_only_change_me@127.0.0.1:5432/aj_mock_hub?schema=aj_mock_hub_test
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379
WORKSPACE_ROOT=storage/workspaces
ANGULAR_TEMPLATE_ROOT=templates/angular-starter
ANGULAR_BUILDER_IMAGE=aj-mock-hub-angular-builder:node22-v1
BUILDER_TIMEOUT_MS=300000
MINIO_ROOT_USER=aj_mock_hub
MINIO_ROOT_PASSWORD=local_only_change_me_now
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
MINIO_ENDPOINT=127.0.0.1
MINIO_USE_SSL=false
MINIO_REQUIREMENTS_BUCKET=requirements
MINIO_PREVIEWS_BUCKET=previews
MINIO_EXPORTS_BUCKET=exports
EXPORT_SIGNING_SECRET=local_only_export_signing_secret_change_before_production
EXPORT_LINK_TTL_SECONDS=86400
APP_PUBLIC_URL=http://127.0.0.1:4200
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
EXPORT_EMAIL_FROM=AJ Mock Hub <no-reply@aj-mock-hub.local>
# Use "local" for deterministic offline development, or "azure-openai" with the values below.
REQUIREMENTS_PROVIDER=local
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_TIMEOUT_MS=60000
AZURE_OPENAI_MAX_RETRIES=2
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
API_PORT=3000
WORKER_PORT=3001
