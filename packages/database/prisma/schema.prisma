generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "cjs"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  ACTIVE
}

enum ProjectVersionStatus {
  DRAFT
}

enum ProjectVersionSourceType {
  MANUAL
  REVISION
  DUPLICATE
  RESTORE
}

enum PipelineJobType {
  WORKSPACE_PREPARATION
  ISOLATED_BUILD
  ANGULAR_GENERATION
  TARGETED_REVISION
}

enum DraftRevisionStatus {
  VALIDATING
  READY
  ACCEPTED
  DISCARDED
  FAILED
}

enum PipelineJobStatus {
  QUEUED
  ACTIVE
  RETRYING
  CANCEL_REQUESTED
  CANCELLED
  COMPLETED
  FAILED
}

enum PipelineJobLogLevel {
  INFO
  WARN
  ERROR
}

enum RequirementDocumentStatus {
  UPLOADED
  EXTRACTED
  FAILED
}

enum UiSpecificationStatus {
  DRAFT
  APPROVED
}

model Project {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String                @db.VarChar(120)
  description    String?               @db.VarChar(2000)
  status         ProjectStatus         @default(ACTIVE)
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  versions       ProjectVersion[]
  jobs           PipelineJob[]
  documents      RequirementDocument[]
  specifications UiSpecification[]
  previews       StaticPreview[]
  revisions      DraftRevision[]
  exports        DeveloperExport[]

  @@index([createdAt(sort: Desc)], map: "projects_created_at_idx")
  @@map("projects")
}

model ProjectVersion {
  id                   String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId            String                   @map("project_id") @db.Uuid
  versionNumber        Int                      @map("version_number")
  label                String                   @db.VarChar(120)
  status               ProjectVersionStatus     @default(DRAFT)
  sourceType           ProjectVersionSourceType @default(MANUAL) @map("source_type")
  instructionsSnapshot String                   @map("instructions_snapshot") @db.Text
  createdAt            DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  project              Project                  @relation(fields: [projectId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  jobs                 PipelineJob[]
  documents            RequirementDocument[]
  specification        UiSpecification?
  preview              StaticPreview?
  baseRevisions         DraftRevision[] @relation("RevisionBaseVersion")
  acceptedRevision      DraftRevision?  @relation("RevisionAcceptedVersion")
  exports               DeveloperExport[]

  @@unique([projectId, versionNumber], map: "project_versions_project_id_version_number_key")
  @@map("project_versions")
}

model DeveloperExport {
  id               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId        String                @map("project_id") @db.Uuid
  projectVersionId String                @map("project_version_id") @db.Uuid
  storageKey       String                @unique(map: "developer_exports_storage_key_key") @map("storage_key") @db.VarChar(500)
  fileName         String                @map("file_name") @db.VarChar(180)
  contentHash      String                @map("content_hash") @db.Char(64)
  byteSize         Int                   @map("byte_size")
  fileCount        Int                   @map("file_count")
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  project          Project               @relation(fields: [projectId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  projectVersion   ProjectVersion        @relation(fields: [projectVersionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  downloads        ExportDownloadAudit[]

  @@index([projectId, createdAt(sort: Desc)], map: "developer_exports_project_created_at_idx")
  @@index([projectVersionId, createdAt(sort: Desc)], map: "developer_exports_version_created_at_idx")
  @@map("developer_exports")
}

model ExportDownloadAudit {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  exportId   String          @map("export_id") @db.Uuid
  downloadedAt DateTime      @default(now()) @map("downloaded_at") @db.Timestamptz(3)
  export     DeveloperExport @relation(fields: [exportId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([exportId, downloadedAt(sort: Desc)], map: "export_download_audits_export_downloaded_at_idx")
  @@map("export_download_audits")
}

model RequirementDocument {
  id               String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId        String                    @map("project_id") @db.Uuid
  projectVersionId String                    @map("project_version_id") @db.Uuid
  originalName     String                    @map("original_name") @db.VarChar(255)
  mediaType        String                    @map("media_type") @db.VarChar(100)
  byteSize         Int                       @map("byte_size")
  storageKey       String                    @unique(map: "requirement_documents_storage_key_key") @map("storage_key") @db.VarChar(500)
  extractedTextKey String?                   @map("extracted_text_key") @db.VarChar(500)
  status           RequirementDocumentStatus @default(UPLOADED)
  errorMessage     String?                   @map("error_message") @db.VarChar(500)
  createdAt        DateTime                  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime                  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  project          Project                   @relation(fields: [projectId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  projectVersion   ProjectVersion            @relation(fields: [projectVersionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([projectVersionId, createdAt], map: "requirement_documents_version_created_at_idx")
  @@map("requirement_documents")
}

model UiSpecification {
  id               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId        String                @map("project_id") @db.Uuid
  projectVersionId String                @unique(map: "ui_specifications_project_version_id_key") @map("project_version_id") @db.Uuid
  status           UiSpecificationStatus @default(DRAFT)
  content          Json                  @db.JsonB
  approvedAt       DateTime?             @map("approved_at") @db.Timestamptz(3)
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt        DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  project          Project               @relation(fields: [projectId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  projectVersion   ProjectVersion        @relation(fields: [projectVersionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([projectId, createdAt(sort: Desc)], map: "ui_specifications_project_created_at_idx")
  @@map("ui_specifications")
}

model PipelineJob {
  id                      String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId               String            @map("project_id") @db.Uuid
  projectVersionId        String            @map("project_version_id") @db.Uuid
  type                    PipelineJobType   @default(WORKSPACE_PREPARATION)
  status                  PipelineJobStatus @default(QUEUED)
  idempotencyKey          String            @map("idempotency_key") @db.VarChar(120)
  attempts                Int               @default(0)
  maxAttempts             Int               @default(3) @map("max_attempts")
  cancellationRequestedAt DateTime?         @map("cancellation_requested_at") @db.Timestamptz(3)
  cancelledAt             DateTime?         @map("cancelled_at") @db.Timestamptz(3)
  startedAt               DateTime?         @map("started_at") @db.Timestamptz(3)
  completedAt             DateTime?         @map("completed_at") @db.Timestamptz(3)
  failedAt                DateTime?         @map("failed_at") @db.Timestamptz(3)
  errorCode               String?           @map("error_code") @db.VarChar(80)
  errorMessage            String?           @map("error_message") @db.VarChar(500)
  createdAt               DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt               DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  project                 Project           @relation(fields: [projectId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  projectVersion          ProjectVersion    @relation(fields: [projectVersionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  logs                    PipelineJobLog[]
  previews                 StaticPreview[]
  revision                 DraftRevision?

  @@unique([projectVersionId, idempotencyKey], map: "pipeline_jobs_version_idempotency_key")
  @@index([projectId, createdAt(sort: Desc)], map: "pipeline_jobs_project_created_at_idx")
  @@index([status, createdAt], map: "pipeline_jobs_status_created_at_idx")
  @@map("pipeline_jobs")
}

model StaticPreview {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId        String         @map("project_id") @db.Uuid
  projectVersionId String         @unique(map: "static_previews_project_version_id_key") @map("project_version_id") @db.Uuid
  sourceJobId      String         @map("source_job_id") @db.Uuid
  storagePrefix    String         @map("storage_prefix") @db.VarChar(500)
  entryFile        String         @default("index.html") @map("entry_file") @db.VarChar(120)
  contentHash      String         @map("content_hash") @db.Char(64)
  fileCount        Int            @map("file_count")
  totalBytes       Int            @map("total_bytes")
  publishedAt      DateTime       @default(now()) @map("published_at") @db.Timestamptz(3)
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  projectVersion   ProjectVersion @relation(fields: [projectVersionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  sourceJob        PipelineJob    @relation(fields: [sourceJobId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([projectId, publishedAt(sort: Desc)], map: "static_previews_project_published_at_idx")
  @@index([sourceJobId], map: "static_previews_source_job_id_idx")
  @@index([storagePrefix], map: "static_previews_storage_prefix_idx")
  @@map("static_previews")
}

model DraftRevision {
  id                       String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId                String              @map("project_id") @db.Uuid
  baseProjectVersionId     String              @map("base_project_version_id") @db.Uuid
  acceptedProjectVersionId String?             @unique(map: "draft_revisions_accepted_version_id_key") @map("accepted_project_version_id") @db.Uuid
  pipelineJobId            String              @unique(map: "draft_revisions_pipeline_job_id_key") @map("pipeline_job_id") @db.Uuid
  status                   DraftRevisionStatus @default(VALIDATING)
  instruction              String              @db.VarChar(2000)
  replacementText          String              @map("replacement_text") @db.VarChar(120)
  targetPageId             String              @map("target_page_id") @db.VarChar(120)
  targetElementId          String              @map("target_element_id") @db.VarChar(240)
  targetElementType        String              @map("target_element_type") @db.VarChar(80)
  targetFile               String              @map("target_file") @db.VarChar(240)
  targetLabel              String              @map("target_label") @db.VarChar(240)
  specificationContent     Json?               @map("specification_content") @db.JsonB
  previewStoragePrefix     String?             @map("preview_storage_prefix") @db.VarChar(500)
  previewContentHash       String?             @map("preview_content_hash") @db.Char(64)
  previewFileCount         Int?                @map("preview_file_count")
  previewTotalBytes        Int?                @map("preview_total_bytes")
  errorMessage             String?             @map("error_message") @db.VarChar(500)
  createdAt                DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)
  project                  Project             @relation(fields: [projectId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  baseProjectVersion       ProjectVersion      @relation("RevisionBaseVersion", fields: [baseProjectVersionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  acceptedProjectVersion   ProjectVersion?     @relation("RevisionAcceptedVersion", fields: [acceptedProjectVersionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  pipelineJob              PipelineJob         @relation(fields: [pipelineJobId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([projectId, createdAt(sort: Desc)], map: "draft_revisions_project_created_at_idx")
  @@index([baseProjectVersionId, createdAt(sort: Desc)], map: "draft_revisions_base_version_created_at_idx")
  @@map("draft_revisions")
}

model PipelineJobLog {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobId     String              @map("job_id") @db.Uuid
  sequence  Int
  level     PipelineJobLogLevel
  message   String              @db.VarChar(1000)
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  job       PipelineJob         @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([jobId, sequence], map: "pipeline_job_logs_job_sequence_key")
  @@index([jobId, createdAt], map: "pipeline_job_logs_job_created_at_idx")
  @@map("pipeline_job_logs")
}
