{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": false,
    "paths": {
      "@aj-mock-hub/contracts": ["./packages/contracts/src/index.ts"],
      "@aj-mock-hub/configuration": ["./packages/configuration/src/index.ts"],
      "@aj-mock-hub/storage": ["./packages/storage/src/index.ts"],
      "@aj-mock-hub/angular-standards": [
        "./packages/angular-standards/src/index.ts"
      ],
      "@aj-mock-hub/database": ["./packages/database/src/index.ts"],
      "@aj-mock-hub/job-queue": ["./packages/job-queue/src/index.ts"],
      "@aj-mock-hub/build-runner": ["./packages/build-runner/src/index.ts"],
      "@aj-mock-hub/generation": ["./packages/generation/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
